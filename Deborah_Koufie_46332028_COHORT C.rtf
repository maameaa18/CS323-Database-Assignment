CREATE DATABASE elitevideo_db;\
USE elitevideo_db;\
\
CREATE TABLE PRICE (\
    Price_Code INT PRIMARY KEY,\
    Price_Description VARCHAR(50) NOT NULL,\
    Price_Rentfee DECIMAL(5,2) NOT NULL,\
    Price_Dailylatefee DECIMAL(5,2) NOT NULL\
);\
\
DESC PRICE;\
+--------------------+--------------+------+-----+---------+-------+\
| Field              | Type         | Null | Key | Default | Extra |\
+--------------------+--------------+------+-----+---------+-------+\
| Price_Code         | int(11)      | NO   | PRI | NULL    |       |\
| Price_Description  | varchar(50)  | NO   |     | NULL    |       |\
| Price_Rentfee      | decimal(5,2) | NO   |     | NULL    |       |\
| Price_Dailylatefee | decimal(5,2) | NO   |     | NULL    |       |\
+--------------------+--------------+------+-----+---------+-------+\
\
CREATE TABLE MOVIE (\
    Movie_Num INT PRIMARY KEY,\
    Movie_Name VARCHAR(100) NOT NULL,\
    Movie_Year INT NOT NULL,\
    Movie_Cost DECIMAL(6,2) NOT NULL,\
    Movie_Genre VARCHAR(20) NOT NULL,\
    Price_Code INT,\
    FOREIGN KEY (Price_Code) REFERENCES PRICE(Price_Code)\
);\
\
DESC MOVIE;\
+-------------+--------------+------+-----+---------+-------+\
| Field       | Type         | Null | Key | Default | Extra |\
+-------------+--------------+------+-----+---------+-------+\
| Movie_Num   | int(11)      | NO   | PRI | NULL    |       |\
| Movie_Name  | varchar(100) | NO   |     | NULL    |       |\
| Movie_Year  | int(11)      | NO   |     | NULL    |       |\
| Movie_Cost  | decimal(6,2) | NO   |     | NULL    |       |\
| Movie_Genre | varchar(20)  | NO   |     | NULL    |       |\
| Price_Code  | int(11)      | YES  | MUL | NULL    |       |\
+-------------+--------------+------+-----+---------+-------+\
\
CREATE TABLE VIDEO (\
    Vid_Num INT PRIMARY KEY,\
    Vid_Indate DATE NOT NULL,\
    Movie_Num INT NOT NULL,\
    FOREIGN KEY (Movie_Num) REFERENCES MOVIE(Movie_Num)\
);\
\
DESC VIDEO;\
+------------+---------+------+-----+---------+-------+\
| Field      | Type    | Null | Key | Default | Extra |\
+------------+---------+------+-----+---------+-------+\
| Vid_Num    | int(11) | NO   | PRI | NULL    |       |\
| Vid_Indate | date    | NO   |     | NULL    |       |\
| Movie_Num  | int(11) | NO   | MUL | NULL    |       |\
+------------+---------+------+-----+---------+-------+\
\
CREATE TABLE MEMBERSHIP (\
    Mem_Num INT PRIMARY KEY,\
    Mem_Fname VARCHAR(50) NOT NULL,\
    Mem_Lname VARCHAR(50) NOT NULL,\
    Mem_Street VARCHAR(100),\
    Mem_City VARCHAR(50),\
    Mem_State CHAR(2),\
    Mem_Zip CHAR(5),\
    Mem_Balance DECIMAL(6,2)\
);\
\
DESC MEMBERSHIP;\
+-------------+--------------+------+-----+---------+-------+\
| Field       | Type         | Null | Key | Default | Extra |\
+-------------+--------------+------+-----+---------+-------+\
| Mem_Num     | int(11)      | NO   | PRI | NULL    |       |\
| Mem_Fname   | varchar(50)  | NO   |     | NULL    |       |\
| Mem_Lname   | varchar(50)  | NO   |     | NULL    |       |\
| Mem_Street  | varchar(100) | YES  |     | NULL    |       |\
| Mem_City    | varchar(50)  | YES  |     | NULL    |       |\
| Mem_State   | char(2)      | YES  |     | NULL    |       |\
| Mem_Zip     | char(5)      | YES  |     | NULL    |       |\
| Mem_Balance | decimal(6,2) | YES  |     | NULL    |       |\
+-------------+--------------+------+-----+---------+-------+\
\
CREATE TABLE RENTAL (\
    Rent_Num INT PRIMARY KEY,\
    Rent_Date DATE NOT NULL,\
    Mem_Num INT NOT NULL,\
    FOREIGN KEY (Mem_Num) REFERENCES MEMBERSHIP(Mem_Num)\
);\
\
DESC RENTAL;\
+-----------+---------+------+-----+---------+-------+\
| Field     | Type    | Null | Key | Default | Extra |\
+-----------+---------+------+-----+---------+-------+\
| Rent_Num  | int(11) | NO   | PRI | NULL    |       |\
| Rent_Date | date    | NO   |     | NULL    |       |\
| Mem_Num   | int(11) | NO   | MUL | NULL    |       |\
+-----------+---------+------+-----+---------+-------+\
\
CREATE TABLE DETAILRENTAL (\
    Rent_Num INT NOT NULL,\
    Vid_Num INT NOT NULL,\
    Detail_Fee DECIMAL(5,2) NOT NULL,\
    Detail_Duedate DATE NOT NULL,\
    Detail_Returndate DATE,\
    Detail_Dailylatefee DECIMAL(5,2) NOT NULL,\
    PRIMARY KEY (Rent_Num, Vid_Num),\
    FOREIGN KEY (Rent_Num) REFERENCES RENTAL(Rent_Num),\
    FOREIGN KEY (Vid_Num) REFERENCES VIDEO(Vid_Num)\
);\
\
DESC DETAILRENTAL;\
+---------------------+--------------+------+-----+---------+-------+\
| Field               | Type         | Null | Key | Default | Extra |\
+---------------------+--------------+------+-----+---------+-------+\
| Rent_Num            | int(11)      | NO   | PRI | NULL    |       |\
| Vid_Num             | int(11)      | NO   | PRI | NULL    |       |\
| Detail_Fee          | decimal(5,2) | NO   |     | NULL    |       |\
| Detail_Duedate      | date         | NO   |     | NULL    |       |\
| Detail_Returndate   | date         | YES  |     | NULL    |       |\
| Detail_Dailylatefee | decimal(5,2) | NO   |     | NULL    |       |\
+---------------------+--------------+------+-----+---------+-------+\
\
