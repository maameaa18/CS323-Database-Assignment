\f0\b QUESTION 28
\f1\b0 \
\
SELECT m.Movie_Num,\
       m.Movie_Genre,\
       ROUND(genre_avg.Avg_Genre_Cost, 2) AS Avg_Genre_Cost,\
       m.Movie_Cost,\
       ROUND(((m.Movie_Cost - genre_avg.Avg_Genre_Cost) / genre_avg.Avg_Genre_Cost * 100), 2) AS Percent_Difference\
FROM MOVIE AS m\
JOIN (\
    SELECT Movie_Genre, AVG(Movie_Cost) AS Avg_Genre_Cost\
    FROM MOVIE\
    GROUP BY Movie_Genre\
) AS genre_avg\
ON m.Movie_Genre = genre_avg.Movie_Genre;\
